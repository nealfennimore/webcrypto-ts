{
    "name": "@nfen/webcrypto-ts",
    "version": "0.3.0",
    "description": "Enforced Webcrypto wrapper",
    "keywords": [
        "aes-cbc",
        "aes-ctr",
        "aes-gcm",
        "aes-kw",
        "aes",
        "curve25519",
        "curve448",
        "ecdh",
        "ecdsa",
        "ed25519",
        "ed448",
        "elliptic-curve",
        "hkdf",
        "hmac",
        "kmac",
        "ml-dsa",
        "ml-kem",
        "pbkdf",
        "post-quantum",
        "rsa-oaep",
        "rsa-pkcs1",
        "rsa-pss",
        "rsa",
        "sha256",
        "sha384",
        "sha512",
        "webcrypto-api",
        "webcrypto",
        "x25519",
        "x448"
    ],
    "types": "./lib/index.d.js",
    "main": "./lib/index.js",
    "exports": {
        ".": "./lib/index.js",
        "./lib/*": "./lib/*.js",
        "./lib/aes/*": "./lib/aes/*.js",
        "./lib/curve25519/*": "./lib/curve25519/*.js",
        "./lib/curve448/*": "./lib/curve448/*.js",
        "./lib/ec/*": "./lib/ec/*.js",
        "./lib/hmac/*": "./lib/hmac/*.js",
        "./lib/kdf/*": "./lib/kdf/*.js",
        "./lib/kmac/*": "./lib/kmac/*.js",
        "./lib/ml_dsa/*": "./lib/ml_dsa/*.js",
        "./lib/ml_kem/*": "./lib/ml_kem/*.js",
        "./lib/rsa/*": "./lib/rsa/*.js",
        "./lib/sha/*": "./lib/sha/*.js"
    },
    "type": "module",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "prepublishOnly": "npm run test && npm run build",
        "prepare": "npm run build",
        "prebuild": "rm -rf lib",
        "build": "tsc --build",
        "watch": "tsc --watch",
        "test": "jest",
        "doc": "npx typedoc --theme oxide --options ./typedoc.json --entryPointStrategy expand --exclude '**/__tests__/*' --out docs src"
    },
    "author": "Neal Fennimore",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/nealfennimore/webcrypto-ts.git"
    },
    "files": [
        "lib/**/*"
    ],
    "devDependencies": {
        "@nfen/typedoc-theme-oxide": "^0.1.11",
        "@types/jest": "^28.1.6",
        "@types/webcrypto": "^0.0.28",
        "jest": "^28.1.3",
        "jest-environment-jsdom": "^28.1.3",
        "ts-jest": "^28.0.7",
        "typedoc": "^0.22.18",
        "typescript": "^4.7.4"
    }
}
